# Zoho Bug Track — Per-User Configuration

# Server port (default: 3000)
PORT=3000

# Zoho OAuth App Credentials (from https://api-console.zoho.in/)
# Create a "Server-based Application" with redirect URI:
#   http://localhost:3000/auth/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Default Zoho portal & project (users can override in settings)
ZOHO_PORTAL=logmanagementcloud
ZOHO_PROJECT_ID=334688000000017255

# Session secret (any random string)
SESSION_SECRET=change-me-to-random-string
